{
  "name": "@shadowkit/devtools",
  "version": "1.0.0",
  "description": "Runtime hooks for the shadowkit Chrome DevTools panel. Tap bridge messages, store snapshots, and lifecycle events.",
  "license": "MIT",
  "author": "Mateo Kadiu",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateokadiu/shadowkit.git",
    "directory": "packages/devtools"
  },
  "keywords": [
    "devtools",
    "chrome-extension",
    "web-components",
    "shadowkit"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint TBD'",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepare": "tsc -b"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "jsdom": "^25.0.1"
  },
  "publishConfig": { "access": "public" }
}
